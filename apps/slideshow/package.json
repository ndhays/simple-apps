{
  "name": "slideshow",
  "version": "0.0.6",
  "author": {
    "name": "Nick Demarest",
    "email": "ndhays@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ndhays/simple-apps"
  },
  "private": true,
  "description": "A beautiful local image slideshow app",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build-dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.nickdemarest.slideshow",
    "electronVersion": "28.3.3",
    "productName": "Slideshow",
    "mac": {
      "category": "public.app-category.photography",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Slideshow"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Graphics"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
