{
  "name": "music-player",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx electron-builder --mac --project apps/music-player"
      },
      "configurations": {
        "release": {
          "command": "npx electron-builder --mac --publish always --project apps/music-player"
        }
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx electron .",
        "cwd": "apps/music-player"
      }
    }
  }
}