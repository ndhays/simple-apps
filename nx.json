{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default"
    ],
    "sharedGlobals": []
  },
  "release": {
    "projectsRelationship": "independent",
    "projects": [
      "slideshow",
      "music-player"
    ],
    "git": {
      "commit": true,
      "tag": true,
      "push": true
    }
  }
}
